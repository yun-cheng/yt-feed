{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "autoPort": true,
      "cwd": "frontend"
    },
    {
      "name": "backend",
      "runtimeExecutable": ".venv/bin/uvicorn",
      "runtimeArgs": ["app.main:app", "--reload", "--port", "8000"],
      "port": 8000,
      "cwd": "backend"
    },
    {
      "name": "meilisearch",
      "runtimeExecutable": "meilisearch",
      "runtimeArgs": ["--db-path", "data/meili", "--http-addr", "127.0.0.1:7700", "--no-analytics"],
      "port": 7700,
      "cwd": "."
    }
  ]
}
